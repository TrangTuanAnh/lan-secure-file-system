# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=coordinator
DB_USER=coordinator_user
DB_PASSWORD=secure_password
DB_POOL_SIZE=20

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_POOL_SIZE=10

# Server Configuration
SERVER_CLIENT_PORT=8080
SERVER_STORAGE_PORT=8081
SERVER_NOTIFICATION_PORT=8082

# Session Configuration
SESSION_TTL_SECONDS=86400

# Ticket Configuration
UPLOAD_TICKET_TTL_SECONDS=1800
DOWNLOAD_TICKET_TTL_SECONDS=900

# Upload Configuration
UPLOAD_CHUNK_SIZE=524288

# Storage Node Configuration
STORAGE_NODE_HEARTBEAT_INTERVAL=30
STORAGE_NODE_TIMEOUT=90
STORAGE_NODE_SECRET=change-this-secret-in-production

# Client-plane TLS (port 8080 only). Wraps the remote client<->coordinator
# connection in TLS. The storage-node control plane (8081) stays plaintext.
# When enabled, mount/provide a cert+key (e.g. self-signed with the public IP
# in subjectAltName). The matching client sets BACKEND_TLS=true.
CLIENT_TLS_ENABLED=false
CLIENT_TLS_CERT=/app/certs/server.crt
CLIENT_TLS_KEY=/app/certs/server.key

# Internal mTLS (component-to-component). Each requires a CA-issued cert/key.
# Storage-node control plane (8081): require + verify the node's client cert.
STORAGE_TLS_ENABLED=false
STORAGE_TLS_CERT=/app/certs/internal/coordinator.crt
STORAGE_TLS_KEY=/app/certs/internal/coordinator.key
STORAGE_TLS_CA=/app/certs/internal/ca.crt
# PostgreSQL mTLS (verify-full): present client cert, verify server cert + host.
DB_SSLMODE=disable
DB_SSLCERT=/app/certs/internal/coordinator.crt
DB_SSLKEY=/app/certs/internal/coordinator.key
DB_SSLROOTCERT=/app/certs/internal/ca.crt
# Redis mTLS: present client cert, verify server cert.
REDIS_SSL=false
REDIS_SSL_CERT=/app/certs/internal/coordinator.crt
REDIS_SSL_KEY=/app/certs/internal/coordinator.key
REDIS_SSL_CA=/app/certs/internal/ca.crt
