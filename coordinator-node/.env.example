# ==========================================
# LAN Secure File System - Local Dev Config
# ==========================================

APP_ENV=development
APP_DEBUG=true

# Coordinator client API
COORDINATOR_HOST=localhost
COORDINATOR_PORT=8080
BACKEND_HOST=localhost
BACKEND_PORT=8080

# Backend request/socket settings
BACKEND_TIMEOUT=15
BACKEND_SOCKET_TIMEOUT=5
BACKEND_MAX_RETRIES=2
BACKEND_RETRY_DELAY=1

# Notification server, nếu sau này dùng riêng
NOTIFICATION_HOST=localhost
NOTIFICATION_PORT=8082

# Storage node fallback/debug.
# Upload/download chuẩn nên lấy storage address từ backend.

ADMIN_USERNAMES=admin
STORAGE_HOST=localhost
STORAGE_PORT=9001


