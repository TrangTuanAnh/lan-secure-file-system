<Window x:Class="frontend.Views.SignupView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SignupView"
        Width="1200"
        Height="750"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#121212">

    <!-- SCALE TOÀN BỘ -->
    <Viewbox Stretch="Uniform">

        <!-- DESIGN GỐC -->
        <Grid Width="1440" Height="900">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="557*"/>
                    <RowDefinition Height="327*"/>
                </Grid.RowDefinitions>

                <!-- Background circles -->
                <Image Source="pack://application:,,,/frontend;component/Assets/ellipse1_blue.png"
                       Width="230"
                       Opacity="0.9"
                       Panel.ZIndex="-1"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top"
                       Margin="820,80,0,0"/>

                <Image Source="pack://application:,,,/frontend;component/Assets/ellipse1_blue.png"
                       Width="183"
                       Opacity="0.9"
                       Panel.ZIndex="0"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       Margin="1226,0,0,0"
                       Grid.Row="1"/>

                <!-- Main layout -->
                <Grid Margin="80" Grid.RowSpan="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT -->
                    <StackPanel VerticalAlignment="Center">

                        <TextBlock Text="Transfer Files Seamlessly"
                                   FontSize="52"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <TextBlock Text="Upload, download and manage your files securely using FTP."
                                   FontSize="16"
                                   Foreground="#AAAAAA"
                                   Margin="0,20,0,0"
                                   Width="500"
                                   TextWrapping="Wrap"/>

                    </StackPanel>

                    <!-- RIGHT -->
                    <Border Grid.Column="1"
                            Width="420"
                            Padding="30"
                            CornerRadius="20"
                            Background="#1FFFFFFF"
                            BorderBrush="#40FFFFFF"
                            BorderThickness="1"
                            VerticalAlignment="Center">

                        <StackPanel>

                            <TextBlock Text="Signup"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="White"/>

                            <TextBlock Text="Just some details to get you in.!"
                                       Margin="0,5,0,20"
                                       Foreground="#CCCCCC"/>

                            <!-- Username -->
                            <Border CornerRadius="10" Background="#33FFFFFF" Margin="0,10">
                                <TextBox x:Name="txtUsername"
                                       Height="42"
                                       Background="Transparent"
                                       Foreground="Gray"
                                       BorderThickness="0"
                                       Padding="12"
                                       Text="Username"
                                       GotFocus="Username_GotFocus"
                                       LostFocus="Username_LostFocus"/>
                            </Border>

                            <!-- Email -->
                            <Border CornerRadius="10" Background="#33FFFFFF" Margin="0,10">
                                <TextBox x:Name="txtEmail"
                                       Height="42"
                                       Background="Transparent"
                                       Foreground="Gray"
                                       BorderThickness="0"
                                       Padding="12"
                                       Text="Email / Phone"
                                       GotFocus="Email_GotFocus"
                                       LostFocus="Email_LostFocus"/>
                            </Border>

                            <!-- Password -->
                            <Border CornerRadius="10" Background="#33FFFFFF" Margin="0,10">
                                <Grid>
                                    <PasswordBox x:Name="txtPassword"
                                       Height="42"
                                       Background="Transparent"
                                       Foreground="White"
                                       BorderThickness="0"
                                       Padding="12"
                                       GotFocus="Password_GotFocus"
                                       LostFocus="Password_LostFocus"/>

                                    <TextBlock x:Name="txtPasswordPlaceholder"
                                       Text="Password"
                                       Foreground="Gray"
                                       Margin="12,0"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"/>
                                </Grid>
                            </Border>

                            <!-- Confirm Password -->
                            <Border CornerRadius="10" Background="#33FFFFFF" Margin="0,10">
                                <Grid>
                                    <PasswordBox x:Name="txtConfirmPassword"
                                       Height="42"
                                       Background="Transparent"
                                       Foreground="White"
                                       BorderThickness="0"
                                       Padding="12"
                                       GotFocus="ConfirmPassword_GotFocus"
                                       LostFocus="ConfirmPassword_LostFocus"/>

                                    <TextBlock x:Name="txtConfirmPasswordPlaceholder"
                                       Text="Confirm Password"
                                       Foreground="Gray"
                                       Margin="12,0"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"/>
                                </Grid>
                            </Border>

                            <!-- Button -->
                            <Button Height="48"
                                    Margin="0,10"
                                    Content="Signup"
                                    Foreground="White"
                                    FontWeight="Bold"
                                    Click="Signup_Click">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#3A7BFF" Offset="0"/>
                                        <GradientStop Color="#1E3AFF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Button.Background>
                            </Button>

                            <!-- Divider -->
                            <Grid Margin="0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>

                                <Rectangle Height="1" Fill="#555"/>
                                <TextBlock Text="Or"
                                           Foreground="#AAA"
                                           Margin="10,0"
                                           Grid.Column="1"/>
                                <Rectangle Height="1"
                                           Fill="#555"
                                           Grid.Column="2"/>
                            </Grid>

                            <!-- Social -->
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center">

                                <Image Source="pack://application:,,,/frontend;component/Assets/google.png" Width="36" Margin="10"/>
                                <Image Source="pack://application:,,,/frontend;component/Assets/facebook.png" Width="36" Margin="10"/>
                                <Image Source="pack://application:,,,/frontend;component/Assets/github.png" Width="36" Margin="10"/>

                            </StackPanel>

                            <!-- Back -->
                            <TextBlock Text="Already Registered? Login"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       Margin="0,20,0,10"
                                       MouseDown="BackToLogin_Click"
                                       Cursor="Hand"/>

                        </StackPanel>
                    </Border>

                </Grid>
            </Grid>

        </Grid>

    </Viewbox>

</Window>