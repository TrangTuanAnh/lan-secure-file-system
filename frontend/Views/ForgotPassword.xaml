<Window x:Class="frontend.Views.ForgotPasswordView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ForgotPasswordView"
        Width="1200"
        Height="750"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#121212">

    <!-- SCALE -->
    <Viewbox Stretch="Uniform">

        <!-- DESIGN GỐC -->
        <Grid Width="1440" Height="900">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="557*"/>
                    <RowDefinition Height="327*"/>
                </Grid.RowDefinitions>

                <!-- Background circles -->
                <Image Source="pack://application:,,,/frontend;component/Assets/ellipse1_pink.png"
                       Width="230"
                       Opacity="0.9"
                       Panel.ZIndex="-1"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top"
                       Margin="820,80,0,0"/>

                <Image Source="pack://application:,,,/frontend;component/Assets/ellipse2_pink.png"
                       Width="183"
                       Opacity="0.9"
                       Panel.ZIndex="0"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       Margin="1226,0,0,0"
                       Grid.Row="1"/>

                <!-- Main layout -->
                <Grid Margin="80" Grid.RowSpan="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT -->
                    <StackPanel VerticalAlignment="Center">

                        <TextBlock Text="Transfer Files Seamlessly"
                                   FontSize="52"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <TextBlock Text="Upload, download and manage your files securely using FTP."
                                   FontSize="16"
                                   Foreground="#AAAAAA"
                                   Margin="0,20,0,0"
                                   Width="500"
                                   TextWrapping="Wrap"/>

                    </StackPanel>

                    <!-- RIGHT -->
                    <Border Grid.Column="1"
                            Width="420"
                            Padding="30"
                            CornerRadius="20"
                            Background="#1FFFFFFF"
                            BorderBrush="#40FFFFFF"
                            BorderThickness="1"
                            VerticalAlignment="Center">

                        <StackPanel>

                            <TextBlock Text="Forgot Password ?"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="White"/>

                            <TextBlock Text="Please enter your email"
                                       Margin="0,5,0,20"
                                       Foreground="#CCCCCC"/>

                            <!-- Email -->
                            <Border CornerRadius="10" Background="#33FFFFFF" Margin="0,10">
                                <TextBox x:Name="txtEmail"
                                       Height="42"
                                       Background="Transparent"
                                       Foreground="Gray"
                                       BorderThickness="0"
                                       Padding="12"
                                       Text="Email / Phone"
                                       GotFocus="Email_GotFocus"
                                       LostFocus="Email_LostFocus"/>
                            </Border>

                            <!-- Button -->
                            <Button Height="48"
                                    Margin="0,10"
                                    Content="Reset Password"
                                    Foreground="White"
                                    FontWeight="Bold"
                                    Click="Reset_Click">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#FF4DA6" Offset="0"/>
                                        <GradientStop Color="#FF0055" Offset="1"/>
                                    </LinearGradientBrush>
                                </Button.Background>
                            </Button>

                            <!-- Back -->
                            <TextBlock Text="Take me back"
                                       Foreground="#BBBBBB"
                                       HorizontalAlignment="Center"
                                       Margin="0,10"
                                       MouseDown="BackToLogin_Click"
                                       Cursor="Hand"/>

                            <!-- Footer -->
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Margin="0,30,0,0">

                                <TextBlock Text="Terms &amp; Conditions"
                                           Foreground="#888"
                                           Margin="10,0"/>

                                <TextBlock Text="Support"
                                           Foreground="#888"
                                           Margin="10,0"/>

                                <TextBlock Text="Customer Care"
                                           Foreground="#888"
                                           Margin="10,0"/>

                            </StackPanel>

                        </StackPanel>
                    </Border>

                </Grid>
            </Grid>

        </Grid>

    </Viewbox>

</Window>